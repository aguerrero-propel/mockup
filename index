    <link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Libre Franklin', sans-serif;
            background: #f8f9fa;
            color: #333;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid #e5e5e5;
        }

        .header-title {
            font-size: 16px;
            font-weight: 700;
        }

        .header-title .propel {
            color: #fc5c3a;
        }

        .header-title .academy {
            color: #2c59b7;
        }

        .stats-overview {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
            padding: 20px;
            border-radius: 8px;
            border: 1px solid #d6e2f0;
            text-align: center;
        }

        .country-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            margin-left: 6px;
        }

        .country-ar {
            background: #e0e8f7;
            color: #2c59b7;
        }

        .country-cl {
            background: #d6e2f0;
            color: #486ec8;
        }

        .country-uy {
            background: #ccd9e8;
            color: #618ece;
        }

        .country-mx {
            background: #c2d0e0;
            color: #486ec8;
        }

        .stat-label {
            font-size: 11px;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 700;
            color: #2c59b7;
            margin-bottom: 4px;
        }

        .stat-sub {
            font-size: 11px;
            color: #ccc;
        }

        .tabs {
            display: flex;
            gap: 12px;
            margin-bottom: 24px;
            border-bottom: 1px solid #e5e5e5;
            padding-bottom: 0;
            overflow-x: auto;
        }

        .tab-btn {
            padding: 12px 16px;
            background: transparent;
            border: none;
            cursor: pointer;
            font-size: 13px;
            color: #999;
            white-space: nowrap;
            border-bottom: 3px solid transparent;
            font-weight: 500;
            font-family: 'Libre Franklin', sans-serif;
            transition: all 0.2s;
        }

        .tab-btn:hover {
            color: #2c59b7;
        }

        .tab-btn.active {
            color: #2c59b7;
            border-bottom-color: #fc5c3a;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        .section {
            background: white;
            padding: 20px;
            border-radius: 8px;
            border: 1px solid #e5e5e5;
            margin-bottom: 16px;
        }

        .section-title {
            font-size: 13px;
            font-weight: 600;
            color: #2c59b7;
            margin-bottom: 16px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Funnel styles */
        .funnel {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .funnel-step {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .funnel-bar {
            height: 40px;
            background: #2c59b7;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 12px;
            color: white;
            font-weight: 600;
            font-size: 13px;
            min-width: 150px;
        }

        .funnel-label {
            font-size: 12px;
            color: #666;
            font-weight: 500;
            min-width: 140px;
        }

        .funnel-percent {
            font-size: 11px;
            color: #999;
        }

        /* Table styles */
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

        thead {
            background: #f5f5f5;
            border-bottom: 1px solid #e5e5e5;
        }

        th {
            padding: 12px;
            text-align: left;
            font-weight: 600;
            color: #666;
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 0.4px;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #f0f0f0;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tbody tr:hover {
            background: #fafafa;
        }

        .value-primary {
            color: #2c59b7;
            font-weight: 600;
        }

        .value-secondary {
            color: #486ec8;
            font-weight: 600;
        }

        .value-accent {
            color: #fc5c3a;
            font-weight: 600;
        }

        /* Bar chart styles */
        .bars-container {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .bar-item {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .bar-label {
            font-size: 12px;
            color: #666;
            min-width: 120px;
            font-weight: 500;
        }

        .bar-wrapper {
            flex: 1;
            background: #f0f0f0;
            height: 28px;
            border-radius: 4px;
            position: relative;
        }

        .bar-fill {
            height: 100%;
            background: #2c59b7;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 10px;
            font-size: 11px;
            color: white;
            font-weight: 600;
        }

        /* Metrics grid */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 12px;
        }

        .metric-box {
            background: #f8f9fa;
            padding: 16px;
            border-radius: 6px;
            border: 1px solid #e5e5e5;
        }

        .metric-label {
            font-size: 11px;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .metric-value {
            font-size: 24px;
            font-weight: 700;
            color: #2c59b7;
        }

        /* Explanation box */
        .explanation-box {
            background: #f0f7ff;
            padding: 14px;
            border-radius: 6px;
            border-left: 3px solid #fc5c3a;
            font-size: 12px;
            color: #666;
            line-height: 1.6;
            margin-top: 12px;
        }

        .explanation-box strong {
            color: #2c59b7;
        }

        /* Tooltip */
        .tooltip {
            position: relative;
            display: inline;
            border-bottom: 1px dotted #fc5c3a;
            cursor: help;
            color: #fc5c3a;
            font-weight: 600;
        }

        .tooltip .tooltiptext {
            visibility: hidden;
            width: 220px;
            background-color: #2c59b7;
            color: white;
            text-align: left;
            border-radius: 4px;
            padding: 10px;
            position: absolute;
            z-index: 1;
            bottom: 125%;
            left: 50%;
            margin-left: -110px;
            opacity: 0;
            transition: opacity 0.3s;
            font-size: 11px;
            font-weight: 400;
            white-space: normal;
        }

        .tooltip:hover .tooltiptext {
            visibility: visible;
            opacity: 1;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .header {
                flex-direction: column;
                gap: 12px;
                align-items: flex-start;
            }

            .stats-overview {
                grid-template-columns: 1fr;
            }

            .metrics-grid {
                grid-template-columns: 1fr;
            }

            .tabs {
                gap: 6px;
            }

            .tab-btn {
                padding: 8px 12px;
                font-size: 11px;
            }
        }
    </style>
</head>
